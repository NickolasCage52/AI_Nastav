# Telegram Bot Settings
# Получить токен у @BotFather командой /newbot или /revoke
TELEGRAM_BOT_TOKEN=

# Ваш chat_id: написать боту, затем открыть
# https://api.telegram.org/bot<TOKEN>/getUpdates
# и найти "chat":{"id":...}
TELEGRAM_CHAT_ID=

# Только локальная разработка: если с ПК не открывается api.telegram.org, заявки проксируются на прод.
# На Vercel в Settings → Environment Variables задай TELEGRAM_BOT_TOKEN и TELEGRAM_CHAT_ID, redeploy.
# APPLY_UPSTREAM_URL не задавай на Vercel (только в .env.local для dev).
# APPLY_UPSTREAM_URL=https://your-project.vercel.app
